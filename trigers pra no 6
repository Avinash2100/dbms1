-- BEFORE INSERT TRIGGER

DELIMITER //

CREATE TRIGGER salary_checktrigger
BEFORE INSERT ON Employees
FOR EACH ROW
BEGIN

    IF NEW.salary <= 10000 THEN

        INSERT INTO Employee_Audit(
            emp_id,
            operation,
            old_salary,
            new_salary,
            action_date
        )
        VALUES (
            NEW.emp_id,
            'INVALID_INSERT',
            NULL,
            NEW.salary,
            NOW()
        );

        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Invalid Salary: must be greater than 10000';

    END IF;

END //

DELIMITER ;

