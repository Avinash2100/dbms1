CREATE DATABASE assign4;

USE assign4;

-- CUSTOMER TABLE

CREATE TABLE customer(
    cust_id INT PRIMARY KEY,
    cust_name VARCHAR(20),
    city VARCHAR(15),
    email VARCHAR(30)
);

-- ORDERS TABLE

CREATE TABLE orders(
    or_id INT PRIMARY KEY,
    or_date DATE,
    amount INT,
    cust_id INT,
    FOREIGN KEY (cust_id) REFERENCES customer(cust_id)
);

