-- 1. LEFT JOIN

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       customer.email,
       orders.or_id,
       orders.or_date,
       orders.amount
FROM customer
LEFT JOIN orders
ON customer.cust_id = orders.cust_id;

-- 2. INNER JOIN WITH CONDITION

SELECT customer.cust_name,
       orders.amount
FROM customer
INNER JOIN orders
ON customer.cust_id = orders.cust_id
WHERE orders.amount > 3000;

-- 3. CUSTOMERS WITH MORE THAN ONE ORDER

SELECT customer.cust_id,
       customer.cust_name,
       COUNT(orders.or_id) AS total_orders
FROM customer
INNER JOIN orders
ON customer.cust_id = orders.cust_id
GROUP BY customer.cust_id, customer.cust_name
HAVING COUNT(orders.or_id) > 1;

-- 4. DISPLAY ORDER DETAILS WITH CUSTOMER CITY

SELECT orders.or_id,
       orders.or_date,
       orders.amount,
       customer.city
FROM orders
JOIN customer
ON customer.cust_id = orders.cust_id;

-- 5. CUSTOMERS WITH NO ORDERS

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       customer.email
FROM customer
LEFT JOIN orders
ON customer.cust_id = orders.cust_id
WHERE orders.or_id IS NULL;

-- 6. MAXIMUM ORDER AMOUNT OF EACH CUSTOMER

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       MAX(orders.amount) AS max_amount
FROM customer
JOIN orders
ON customer.cust_id = orders.cust_id
GROUP BY customer.cust_id, customer.cust_name, customer.city;

-- 7. TOTAL ORDER AMOUNT OF EACH CUSTOMER

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       SUM(orders.amount) AS total_amount
FROM customer
JOIN orders
ON customer.cust_id = orders.cust_id
GROUP BY customer.cust_id, customer.cust_name, customer.city;

-- 8. SORT ORDERS BY DATE

SELECT orders.or_id,
       orders.or_date,
       orders.amount,
       customer.cust_name,
       customer.city
FROM orders
JOIN customer
ON orders.cust_id = customer.cust_id
ORDER BY orders.or_date;

-- 9. ORDERS OF CUSTOMERS FROM PUNE

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       orders.or_id,
       orders.or_date,
       orders.amount
FROM customer
JOIN orders
ON customer.cust_id = orders.cust_id
WHERE customer.city = 'Pune';

-- 10. LATEST ORDER DATE OF EACH CUSTOMER

SELECT customer.cust_id,
       customer.cust_name,
       customer.city,
       MAX(orders.or_date) AS latest_order
FROM customer
JOIN orders
ON customer.cust_id = orders.cust_id
GROUP BY customer.cust_id, customer.cust_name, customer.city;
