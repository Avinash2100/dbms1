CREATE DATABASE sales_db;

USE sales_db;

CREATE TABLE sales (
    sale_id INT PRIMARY KEY AUTO_INCREMENT,
    product_name VARCHAR(50),
    quantity INT,
    price DECIMAL(10,2),
    sale_date DATE
);

